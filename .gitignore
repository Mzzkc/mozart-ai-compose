# ═══════════════════════════════════════════════════════════════════════════════
# Marianne Repository Organization
# See .marianne/spec/conventions.yaml (Repository Structure) for full rules
# ═══════════════════════════════════════════════════════════════════════════════

# Workspaces — all job workspaces live under workspaces/ (or legacy dot-prefixed)
workspaces/
*-workspace/
*-workspace-*/
*workspace-*/
.daemon-workspace-*/
test-workspace-*/

# Internal scores — development/QA scores, not for public consumption
scores-internal/

# Session handoff documents
handoffs/

# Logs
*.log
logs/

# Test artifacts
tests/temp/

# Coverage artifacts
.coverage
coverage*.json
dashboard_coverage.json
healing_coverage.json
htmlcov/

# Investigation/debug artifacts
investigation-results/
debug-*.yaml
temp-scores/

# Internal planning and scripts
docs/plans/
/scripts/

# Marianne state files (generated during job execution)
.marianne-state.db
.marianne-outcomes.json
.marianne-pause-*

# Top-level score YAML (generated by evolution jobs, not source)
marianne-*.yaml
marianne-opus-evolution-v*.yaml

# Project-specific context (personal, not for public repo)
.marianne/
CLAUDE.md
memory-bank/
STATUS.md
.claude
.playwright*

# Exceptions: tracked directories that might match patterns above
!examples/
!scores/

# State files (keep structure, ignore contents)
*.json.tmp

# MkDocs generated site
site/

# Hypothesis property-based testing cache
.hypothesis/

# Flowspec (cache and generated output — config.yaml IS tracked)
.flowspec/cache/
.flowspec/*
flowspec*

# OS
.DS_Store
Thumbs.db
