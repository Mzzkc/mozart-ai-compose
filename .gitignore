# ═══════════════════════════════════════════════════════════════════════════════
# Mozart Repository Organization
# See .mozart/spec/conventions.yaml (Repository Structure) for full rules
# ═══════════════════════════════════════════════════════════════════════════════

# Workspaces — all job workspaces live under workspaces/ (or legacy dot-prefixed)
workspaces/
*-workspace/
*-workspace-*/
*workspace-*/
.daemon-workspace-*/
test-workspace-*/

# Internal scores — development/QA scores, not for public consumption
scores-internal/

# Logs
*.log
logs/
!.mozart/state/decisions.log

# Test artifacts
tests/temp/

# Coverage artifacts
.coverage
coverage*.json
dashboard_coverage.json
healing_coverage.json
htmlcov/

# Investigation/debug artifacts
investigation-results/
debug-*.yaml
temp-scores/

# Internal planning and scripts
docs/plans/
scripts/

# Mozart state files (generated during job execution)
.mozart-state.db
.mozart-outcomes.json
.mozart-pause-*

# Top-level score YAML (generated by evolution jobs, not source)
mozart-*.yaml
mozart-opus-evolution-v*.yaml

# Project-specific context (personal, not for public repo)
CLAUDE.md
memory-bank/
STATUS.md

# Exceptions: tracked directories that might match patterns above
!examples/
!scores/

# State files (keep structure, ignore contents)
*.json.tmp

# MkDocs generated site
site/

# Hypothesis property-based testing cache
.hypothesis/

# OS
.DS_Store
Thumbs.db
